class DynamicSectionCut(NXOpen.NXObject): 
    """ Represents a dynamic section-cut generated by sectioning an object
        such as a <ja_class>NXOpen.IBody</ja_class> or a 
        <ja_class>NXOpen.Assemblies.Component</ja_class>. 
    """


    ## Getter for property: (@link NXOpen.INXObject NXOpen.INXObject@endlink) CutObject
