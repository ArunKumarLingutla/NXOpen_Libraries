class CustomFeatureClass(NXOpen.TransientObject): 
    """ Provides interfaces to configure callbacks for a custom feature. """
    CreateFeatureGeometryCallback = Callable[[CustomFeatureCreateFeatureGeometryEvent], None]
    def AddCreateFeatureGeometryHandler(self, createFeatureGeometryCallback: CustomFeatureClass.CreateFeatureGeometryCallback) -> None:
        """
         Registers the custom feature create feature geometry callback. 
                This callback is invoked when custom feature should recreate it's geometric output.
                This callback is meant to allow user to create new geometric output using current input parameters state.
                Geometries created as output of custom feature should be non associative, they should not store recipes.
                Geometries include All types of curves and parasolid bodies.
                All geometries created in this callback should be tracked using Features.TrackingData
                To create parasolid bodies user needs to have parasolid development license.
                Implementations of this callback should not:  
                    - create any feature in this callback.
                    - trigger part save or update from this callback.
                    - log any object to delete or update from this callback.
                    - try to display entities from this callback.
                    - try to launch any user interface from this callback.
        """
        pass
    HighlightCallback = Callable[[CustomFeatureHighlightEvent], None]
    def AddHighlightHandler(self, highlightCallback: CustomFeatureClass.HighlightCallback) -> None:
        """
         Registers the custom feature highlight callback. 
                 This callback is invoked when output of custom feature is to be highlighted or de-highlighted.
                 Implementations of this callback should return any additional entities that should be highlighted or de-highlighted with feature output.
                 Implementations of this callback can also choose to only highlight- de-highlight entities returned from this callback.
                 Implementations of this callback should not:             
                    - trigger part save or update from this callback.
                    - log any object to delete or update from this callback.            
                    - try to display entities from this callback.
                    - try to launch any user interface from this callback.
                    - createdelete any geometric objects in this callback.
