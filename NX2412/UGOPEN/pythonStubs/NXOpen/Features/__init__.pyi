import NXOpen
class IContainerFeature(NXOpen.INXObject): 
    """ Represents a container feature on a part. A container feature contains and maintains other features
 which produce or modify geometry.The container feature does not operate on any geometry directly. Feature 
 such as NXOpen.Features.PatternFeature is an example of container feature. """
    @abstractmethod
    def GetAllContainedFeatures(self) -> List[Feature]:
        """
         Returns all the features contained in this container feature. This method will cycle through any container features contained by this container feature to return the complete set of contained features. 
         Returns contained_features ( Feature List[NXOpe):  .
        """
        pass
    @abstractmethod
    def GetAssociatedBodies(self) -> List[NXOpen.Body]:
        """
         Returns all the bodies created, modified and split by the container feature's "contained" features 
         Returns bodies ( NXOpen.Body Li):  .
        """
        pass
    @abstractmethod
    def GetAssociatedCurvesPointsDatums(self) -> List[NXOpen.DisplayableObject]:
        """
         Returns all the entities(curves,points and datums) created by the container feature's "contained" features 
         Returns entities ( NXOpen.DisplayableObject Li):  .
        """
        pass
    @abstractmethod
    def GetAssociatedEdges(self) -> List[NXOpen.Edge]:
        """
         Returns all the edges created, modified and split by the container feature's "contained" features 
         Returns edges ( NXOpen.Edge Li):  .
        """
        pass
    @abstractmethod
    def GetAssociatedFaces(self) -> List[NXOpen.Face]:
        """
         Returns all the faces created, modified and split by the container feature's "contained" features 
         Returns faces ( NXOpen.Face Li):  .
        """
        pass
    @abstractmethod
    def GetImmediateContainedFeatures(self) -> List[Feature]:
        """
         Returns the Immediate Contained features within the container feature 
         Returns contained_features ( Feature List[NXOpe):  .
        """
        pass
